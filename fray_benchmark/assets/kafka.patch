+
+// Root-level task: copy Java sources into each project's classes output directories
+// This runs after the main `build` finishes to avoid interfering with compilation (especially Scala joint-compilation).
+tasks.register('copySourcesToClasses') {
+  doLast {
+    subprojects.each { p ->
+      if (!p.plugins.hasPlugin('scala')) {
+        def compileJavaTask = p.tasks.findByName('compileJava')
+        if (compileJavaTask != null && p.sourceSets?.main) {
+          def dest = compileJavaTask.destinationDirectory.get().asFile
+          copy {
+            from(p.sourceSets.main.allSource.matching { include '**/*.java' })
+            into(dest)
+          }
+        }
+
+        def compileTestJavaTask = p.tasks.findByName('compileTestJava')
+        if (compileTestJavaTask != null && p.sourceSets?.test) {
+          def destTest = compileTestJavaTask.destinationDirectory.get().asFile
+          copy {
+            from(p.sourceSets.test.allSource.matching { include '**/*.java' })
+            into(destTest)
+          }
+        }
+      }
+    }
+  }
+}
+
+tasks.named('build') {
+  finalizedBy('copySourcesToClasses')
+}
